{
  "name": "tabby-mobax-suite",
  "version": "0.2.0",
  "description": "MobaXterm-style left sidebar for Tabby: saved SSH sessions, a live cwd-following SFTP file browser, keystroke macros, and a bottom server-stats bar.",
  "keywords": [
    "tabby-plugin",
    "tabby",
    "ssh",
    "sftp",
    "sidebar",
    "macros",
    "mobaxterm"
  ],
  "license": "MIT",
  "author": "hopoduck",
  "homepage": "https://github.com/hopoduck/tabby-mobax-suite#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hopoduck/tabby-mobax-suite.git"
  },
  "bugs": {
    "url": "https://github.com/hopoduck/tabby-mobax-suite/issues"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint && eslint .",
    "lint:fix": "oxlint --fix && eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "pnpm lint && pnpm test && pnpm build"
  },
  "peerDependencies": {
    "@angular/common": "^15",
    "@angular/core": "^15",
    "@angular/forms": "^15",
    "rxjs": "^7",
    "tabby-core": "*",
    "tabby-settings": "*",
    "tabby-ssh": "*",
    "tabby-terminal": "*"
  },
  "devDependencies": {
    "@angular/cdk": "15.2.6",
    "@angular/common": "15.2.6",
    "@angular/core": "15.2.6",
    "@angular/forms": "15.2.6",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "oxlint": "^1.70.0",
    "prettier": "^3.8.4",
    "rxjs": "7.5.7",
    "tabby-core": "1.0.231-nightly.0",
    "tabby-settings": "1.0.231-nightly.0",
    "tabby-ssh": "1.0.231-nightly.0",
    "tabby-terminal": "1.0.231-nightly.0",
    "ts-loader": "^9.5.1",
    "typescript": "~5.4.5",
    "typescript-eslint": "^8.61.1",
    "vitest": "^2.1.0",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4"
  }
}
